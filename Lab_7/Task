library(readxl)
library(dplyr)

titanic <- read.csv("C:/Users/User/Downloads/titanic.csv")

View(titanic)

sum(is.na(titanic))
which(is.na(titanic))
sapply(titanic, function(x) sum(is.na(x)))

dim(titanic)

titanic_cleaned <- na.omit(titanic)

dim(titanic_cleaned)

titanic_cleaned %>%
  summarise(
    Total_Passengers = n(),
    Total_Survived = sum(Survived),
    Survival_Rate = mean(Survived) * 100
  )

titanic_cleaned %>%
  group_by(Sex) %>%
  summarise(
    Passengers = n(),
    Survived = sum(Survived),
    Survival_Rate = mean(Survived) * 100
  )

titanic_cleaned %>%
  group_by(Pclass) %>%
  summarise(
    Passengers = n(),
    Survived = sum(Survived),
    Survival_Rate = mean(Survived) * 100
  )

titanic_cleaned %>%
  group_by(Embarked) %>%
  summarise(
    Passengers = n(),
    Survived = sum(Survived),
    Survival_Rate = mean(Survived) * 100
  )

titanic_cleaned %>%
  group_by(Pclass) %>%
  summarise(
    Count = n(),
    Percentage = n()/nrow(titanic_cleaned)*100
  )

output_file <- "C:/Users/User/Downloads/titanic_cleaned.csv"
write.csv(titanic_cleaned, output_file, row.names = FALSE)

